---
import '../styles/landing.css';

const ghUrl = 'https://github.com/automaat/sybra';
const docsUrl = '/getting-started/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Manage your agentic engineering team. Run agent swarms in parallel — headless or interactive, git-isolated, no SaaS required." />
    <title>Sybra — Multi-agent orchestration</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script is:inline>
      if (!localStorage.getItem('sybra-theme-v2')) {
        localStorage.removeItem('theme');
        localStorage.removeItem('starlight-theme');
        localStorage.setItem('sybra-theme-v2', '1');
      }
      const t = localStorage.getItem('theme') || localStorage.getItem('starlight-theme') || 'light';
      document.documentElement.setAttribute('data-theme', t);
      localStorage.setItem('theme', t);
      localStorage.setItem('starlight-theme', t);
    </script>
  </head>
  <body>

    <!-- ─── NAV ────────────────────────────────────────────── -->
    <nav id="nav" class="site-nav fixed top-0 left-0 right-0 z-50">
      <div class="max-w-screen-xl mx-auto px-6 sm:px-10 md:px-16 lg:px-24 h-14 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2.5" style="font-family: var(--font-display); font-weight: 600; color: var(--color-text);">
          <img src="/favicon.svg" alt="Sybra" class="w-7 h-7" />
          Sybra
        </a>
        <div class="flex items-center gap-6">
          <a href={docsUrl} class="text-sm transition-colors" style="color: var(--color-muted);" onmouseover="this.style.color='var(--color-text)'" onmouseout="this.style.color='var(--color-muted)'">Docs</a>
          <a href={ghUrl} target="_blank" rel="noopener" class="text-sm transition-colors" style="color: var(--color-muted);" onmouseover="this.style.color='var(--color-text)'" onmouseout="this.style.color='var(--color-muted)'">GitHub</a>
          <button id="theme-toggle" aria-label="Toggle theme"
            style="display:flex;align-items:center;justify-content:center;width:32px;height:32px;border-radius:6px;border:1px solid var(--color-border);background:transparent;cursor:pointer;color:var(--color-muted);transition:color 0.2s,border-color 0.2s;"
            onmouseover="this.style.color='var(--color-text)';this.style.borderColor='var(--color-text)'"
            onmouseout="this.style.color='var(--color-muted)';this.style.borderColor='var(--color-border)'">
            <!-- Sun (shown in dark mode) -->
            <svg id="icon-sun" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
            <!-- Moon (shown in light mode) -->
            <svg id="icon-moon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
          </button>
          <a href={`${ghUrl}/releases`} target="_blank" rel="noopener"
             class="text-sm font-medium px-4 py-1.5 rounded-md transition-opacity"
             style="background: var(--color-accent); color: #fff;"
             onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
            Download
          </a>
        </div>
      </div>
    </nav>

    <main>

      <!-- ─── HERO ───────────────────────────────────────────── -->
      <section class="px-6 sm:px-10 md:px-16 lg:px-24" style="height: 100vh; display: flex; flex-direction: column; text-align: center;">

        <!-- Top spacer (nav height) -->
        <div style="height: 56px; flex-shrink: 0;"></div>

        <!-- Top flex spacer — pushes content to center -->
        <div style="flex: 1;"></div>

        <!-- Eyebrow + headline + CTA -->
        <div style="display: flex; flex-direction: column; align-items: center;">
          <div class="hero-eyebrow inline-flex items-center gap-4 reveal" style="margin-bottom: 2rem;">
            <span class="feature-num">Multi-agent orchestration</span>
            <span style="width: 32px; height: 1px; background: var(--color-accent); display: inline-block;"></span>
            <span class="hero-tagline text-xs" style="color: var(--color-muted);">Open source · macOS · Local-first</span>
          </div>

          <h1 class="hero-h1 reveal" style="font-weight: 700; line-height: 0.9; letter-spacing: -0.03em; color: var(--color-text); margin-bottom: 2.5rem;">
            Lead the <span class="accent-text">swarm.</span>
          </h1>

          <div class="flex flex-col items-center gap-6 reveal">
            <p class="hero-desc" style="color: var(--color-muted); max-width: 480px; line-height: 1.65;">
              Local-first task management for agent swarms.
              Headless or interactive. Git-isolated per task.
              Local-first. Headless or interactive.
              Git-isolated per task.
            </p>
            <div class="flex items-center gap-4">
              <a href={`${ghUrl}/releases`} target="_blank" rel="noopener"
                 class="flex items-center gap-2 font-medium rounded-lg px-5 py-2.5 text-sm transition-opacity"
                 style="background: var(--color-accent); color: #fff; font-family: var(--font-display);"
                 onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
                Download
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 2v7M3.5 6l3.5 3.5L10.5 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
              <a href={docsUrl}
                 class="text-sm transition-colors"
                 style="color: var(--color-muted); font-family: var(--font-display);"
                 onmouseover="this.style.color='var(--color-text)'" onmouseout="this.style.color='var(--color-muted)'">
                Docs →
              </a>
            </div>
          </div>
        </div>

        <!-- Bottom spacer -->
        <div style="flex: 1;"></div>

      </section>

      <!-- ─── HOW IT WORKS ──────────────────────────────────── -->
      <section class="px-6 sm:px-10 md:px-16 lg:px-24 py-24" style="border-top: 1px solid var(--color-border);">

        <div class="mb-16 reveal">
          <span class="feature-num">How it works</span>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-0" style="border: 1px solid var(--color-border);">
          {[
            {
              n: '01',
              title: 'Write a task',
              body: 'A task is a markdown file with YAML frontmatter — title, status, mode, tags. Version-controlled. Portable. Editable in any editor.',
            },
            {
              n: '02',
              title: 'Assign an agent',
              body: 'Choose headless for fully autonomous execution, or interactive to open a session you can attach and steer in real time.',
            },
            {
              n: '03',
              title: 'Review and merge',
              body: "The agent works in an isolated git worktree. When it's done, review the diff and merge like any other PR. Worktree is cleaned up automatically.",
            },
          ].map((step, i) => (
            <div class="reveal" style={`padding: 2.5rem; border-right: ${i < 2 ? '1px solid var(--color-border)' : 'none'};`}>
              <div class="feature-num mb-8">{step.n}</div>
              <h3 style="font-size: 1.6rem; font-weight: 600; font-family: var(--font-display); color: var(--color-text); margin-bottom: 1rem;">{step.title}</h3>
              <p style="font-size: 1.1rem; color: var(--color-muted); line-height: 1.7;">{step.body}</p>
            </div>
          ))}
        </div>

      </section>

      <!-- ─── FEATURES ─────────────────────────────────────── -->
      <section class="px-6 sm:px-10 md:px-16 lg:px-24 py-24" style="border-top: 1px solid var(--color-border);">

        <div class="mb-16 reveal">
          <span class="feature-num">Capabilities</span>
        </div>

        <div>
          {[
            {
              n: '01',
              title: 'Task management',
              body: 'YAML frontmatter + GFM markdown. Status, mode, tags, project ID — all in a plain file your VCS already knows about.',
              tag: 'Core',
            },
            {
              n: '02',
              title: 'Headless agents',
              body: 'Spawns claude -p with stream-JSON output. Sybra streams every assistant message, tool call, and result to the UI in real time. Run dozens in parallel.',
              tag: 'Execution',
            },
            {
              n: '03',
              title: 'Interactive mode',
              body: 'Opens an interactive session for work that needs a human in the loop. Attach from any terminal, steer the agent, detach and let it keep going.',
              tag: 'Execution',
            },
            {
              n: '04',
              title: 'Git worktree isolation',
              body: 'Every task gets a dedicated branch and worktree at ~/.sybra/worktrees/<task-id>. Agents never step on each other or your main checkout.',
              tag: 'Git',
            },
            {
              n: '05',
              title: 'GitHub & Todoist sync',
              body: 'Auto-import tasks from GitHub Issues or Todoist projects. Filter by label or project type. Route to the right machine automatically.',
              tag: 'Integrations',
            },
            {
              n: '06',
              title: 'Multi-machine routing',
              body: 'Declare project_types per machine. Work is never duplicated between your laptop and home server — each handles its own queue.',
              tag: 'Deployment',
            },
          ].map((f, i) => (
            <div class="feature-row reveal">
              <div class="shrink-0 w-10">
                <span class="feature-num">{f.n}</span>
              </div>
              <div style="flex: 1; min-width: 0;">
                <h3 style="font-size: 1.3rem; font-weight: 600; font-family: var(--font-display); color: var(--color-text);">{f.title}</h3>
              </div>
              <div style="flex: 3; min-width: 0;">
                <p class="feature-body" style="font-size: 1.05rem; color: var(--color-muted); line-height: 1.7;">{f.body}</p>
              </div>
              <div class="shrink-0 hidden md:block">
                <span style="font-size: 0.7rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-border); border: 1px solid var(--color-border); padding: 3px 8px; border-radius: 4px; font-family: var(--font-display);">{f.tag}</span>
              </div>
            </div>
          ))}
        </div>

      </section>

      <!-- ─── CLI DEMO ──────────────────────────────────────── -->
      <section class="px-6 sm:px-10 md:px-16 lg:px-24 py-24" style="border-top: 1px solid var(--color-border);">
        <div class="cli-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;">

          <div class="reveal">
            <span class="feature-num mb-4 block">CLI</span>
            <h2 style="font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; font-family: var(--font-display); line-height: 1.1; margin-bottom: 1.25rem; color: var(--color-text);">
              Scriptable from anywhere
            </h2>
            <p style="font-size: 1.15rem; color: var(--color-muted); line-height: 1.7; margin-bottom: 1.5rem;">
              <code style="font-family: monospace; color: var(--color-accent); background: var(--color-accent-dim); padding: 2px 6px; border-radius: 4px;">sybra-cli</code> gives you
              full task and project CRUD from the terminal.
              Use it in scripts, Claude Code skills, or CI pipelines.
            </p>
            <a href={docsUrl} style="font-family: var(--font-display); font-size: 0.9rem; color: var(--color-accent);"
               onmouseover="this.style.opacity='0.75'" onmouseout="this.style.opacity='1'">
              Full CLI reference →
            </a>
          </div>

          <div class="terminal reveal">
            <div class="terminal-header">
              <span class="terminal-dot" style="background:#ff5f57;"></span>
              <span class="terminal-dot" style="background:#febc2e;"></span>
              <span class="terminal-dot" style="background:#28c840;"></span>
              <span class="ml-3 text-xs" style="color: var(--color-muted);">zsh</span>
            </div>
            <div class="terminal-body">
              <div class="terminal-comment"># create and queue a task</div>
              <div class="mt-2">
                <span class="terminal-prompt">$ </span>
                <span class="terminal-cmd">sybra-cli</span>
                <span class="terminal-arg"> create --title "Refactor auth" --mode headless</span>
              </div>
              <div class="terminal-output">✓ task-f7d12a created</div>

              <div class="mt-4 terminal-comment"># check what's running</div>
              <div class="mt-2">
                <span class="terminal-prompt">$ </span>
                <span class="terminal-cmd">sybra-cli</span>
                <span class="terminal-arg"> list --status in-progress</span>
              </div>
              <div style="color: #888;" class="mt-1">task-f7d12a  Refactor auth     headless  in-progress</div>
              <div style="color: #888;">task-a8f23c  Add rate limiting  headless  in-progress</div>

              <div class="mt-4 terminal-comment"># mark ready for review</div>
              <div class="mt-2">
                <span class="terminal-prompt">$ </span>
                <span class="terminal-cmd">sybra-cli</span>
                <span class="terminal-arg"> update task-f7d12a --status in-review</span>
              </div>
              <div class="terminal-output">✓ updated</div>
            </div>
          </div>

        </div>
      </section>

    </main>

    <!-- ─── FOOTER ────────────────────────────────────────── -->
    <footer style="border-top: 1px solid var(--color-border); padding: 2.5rem 6vw;">
      <div style="max-width: 1200px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem;">
        <div class="flex items-center gap-3" style="font-family: var(--font-display); font-size: 0.85rem; color: var(--color-muted);">
          <img src="/favicon.svg" alt="" class="w-6 h-6 opacity-60" />
          Sybra · MIT License
        </div>
        <div class="flex items-center gap-8" style="font-size: 0.85rem;">
          <a href={docsUrl} style="color: var(--color-muted);" onmouseover="this.style.color='var(--color-text)'" onmouseout="this.style.color='var(--color-muted)'">Docs</a>
          <a href={ghUrl} target="_blank" rel="noopener" style="color: var(--color-muted);" onmouseover="this.style.color='var(--color-text)'" onmouseout="this.style.color='var(--color-muted)'">GitHub</a>
          <a href={`${ghUrl}/releases`} target="_blank" rel="noopener" style="color: var(--color-muted);" onmouseover="this.style.color='var(--color-text)'" onmouseout="this.style.color='var(--color-muted)'">Releases</a>
        </div>
      </div>
    </footer>

    <script>
      // ── Theme ────────────────────────────────────────────────
      const html = document.documentElement;
      const sunIcon  = document.getElementById('icon-sun');
      const moonIcon = document.getElementById('icon-moon');

      // ── Nav scroll background ────────────────────────────────
      const nav = document.getElementById('nav');
      const updateNav = () => {
        if (!nav) return;
        nav.classList.toggle('is-scrolled', window.scrollY > 10);
      };
      window.addEventListener('scroll', updateNav, { passive: true });

      const applyTheme = (theme: string) => {
        html.setAttribute('data-theme', theme);
        localStorage.setItem('theme', theme);
        // Sync with Starlight's theme key so docs pick up the same preference
        localStorage.setItem('starlight-theme', theme);
        if (sunIcon && moonIcon) {
          sunIcon.style.display  = theme === 'dark'  ? '' : 'none';
          moonIcon.style.display = theme === 'light' ? '' : 'none';
        }
        updateNav();
      };

      // Init — prefer stored key, fall back to light
      applyTheme(localStorage.getItem('theme') ?? localStorage.getItem('starlight-theme') ?? 'light');

      document.getElementById('theme-toggle')?.addEventListener('click', () => {
        applyTheme(html.getAttribute('data-theme') === 'light' ? 'dark' : 'light');
      });

      // ── Scroll reveal ────────────────────────────────────────
      // Transition is applied via JS (not CSS) so the initial opacity:0
      // state carries no transition property — prevents Blink from
      // eagerly promoting elements to GPU compositing layers before
      // any animation runs, which caused a visible color seam in dark mode.
      const observer = new IntersectionObserver(
        (entries) => entries.forEach((e, i) => {
          if (e.isIntersecting) {
            setTimeout(() => {
              (e.target as HTMLElement).style.transition = 'opacity 0.6s ease';
              e.target.classList.add('visible');
            }, i * 60);
            observer.unobserve(e.target);
          }
        }),
        { threshold: 0.08, rootMargin: '0px 0px -30px 0px' }
      );
      document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
    </script>

  </body>
</html>
